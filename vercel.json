{
  "version": 2,
  "functions": {
    "api/gateway.js": {
      "includeFiles": [
        "services/**",
        "bin/**"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/",
      "destination": "/api/gateway"
    },
    {
      "source": "/(.*)",
      "destination": "/api/gateway?route=$1"
    }
  ]
}
